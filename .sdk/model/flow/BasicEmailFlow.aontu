# BasicEmailFlow

main: kit: flow: BasicEmailFlow:
{
  entity: "email",
  kind: "basic",
  name: "BasicEmailFlow",
  step: [
    {
      input: {
        ref: "email_ref01",
        srcdatavar: "email_ref01_data",
        suffix: "_dt0"
      }

      op: "load",
      valid: [
        {
          apply: "TextFieldMark",
          def: {
            mark: "Mark01-email_ref01"
          }
        }
      ]
    }
  ],
  "key$": "BasicEmailFlow"
}